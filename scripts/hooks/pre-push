#!/bin/bash
#
# Pre-push hook for aichatnav
# Runs basic quality checks before pushing to remote
#

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Change to repository root
cd "$(git rev-parse --show-toplevel)" 2>/dev/null || true

# Get current branch
CURRENT_BRANCH=$(git branch --show-current)
echo -e "${BLUE}Pre-push validation for branch: $CURRENT_BRANCH${NC}"
echo ""

# =============================================================================
# JAVASCRIPT SYNTAX CHECK
# =============================================================================
echo -e "${BLUE}Checking JavaScript syntax...${NC}"

# Use node to check syntax of JS files in src/
JS_ERRORS=0
for jsfile in src/*.js; do
    if [ -f "$jsfile" ]; then
        node --check "$jsfile" 2>/dev/null || {
            echo -e "${RED}Syntax error in: $jsfile${NC}"
            JS_ERRORS=1
        }
    fi
done

if [ $JS_ERRORS -eq 1 ]; then
    echo -e "${RED}JavaScript syntax errors found${NC}"
    exit 1
fi
echo -e "${GREEN}OK${NC} JavaScript syntax check passed"

# =============================================================================
# MANIFEST.JSON VALIDATION
# =============================================================================
echo ""
echo -e "${BLUE}Validating manifest.json...${NC}"

if [ -f "src/manifest.json" ]; then
    # Check it's valid JSON
    if command -v python >/dev/null 2>&1; then
        python -c "import json; json.load(open('src/manifest.json'))" 2>/dev/null || {
            echo -e "${RED}manifest.json is not valid JSON${NC}"
            exit 1
        }
    elif command -v node >/dev/null 2>&1; then
        node -e "JSON.parse(require('fs').readFileSync('src/manifest.json','utf8'))" 2>/dev/null || {
            echo -e "${RED}manifest.json is not valid JSON${NC}"
            exit 1
        }
    fi
    echo -e "${GREEN}OK${NC} manifest.json is valid"
else
    echo -e "${YELLOW}WARNING${NC} src/manifest.json not found"
fi

# =============================================================================
# CHECK FOR DEBUG STATEMENTS
# =============================================================================
echo ""
echo -e "${BLUE}Checking for debug statements...${NC}"

# Check for console.log in production code (warning only)
log_count=$(grep -r "console\.log\|console\.debug" src/ --include="*.js" 2>/dev/null | grep -v "//.*console" | wc -l)
if [ "$log_count" -gt 5 ]; then
    echo -e "${YELLOW}WARNING${NC} Many console.log statements found ($log_count)"
    echo "  Consider removing debug logging before release"
fi

# Check for debugger statements (block)
if grep -r "debugger" src/ --include="*.js" 2>/dev/null | grep -v "//.*debugger"; then
    echo -e "${RED}ERROR: debugger statements found${NC}"
    echo "Remove all debugger statements before pushing"
    exit 1
fi

echo -e "${GREEN}OK${NC} No debugger statements found"

# =============================================================================
# VERSION SYNC CHECK
# =============================================================================
echo ""
echo -e "${BLUE}Checking version sync...${NC}"

SYNC_SCRIPT="$(git rev-parse --show-toplevel)/scripts/sync-versions.py"
if [ -f "$SYNC_SCRIPT" ] && command -v python >/dev/null 2>&1; then
    python "$SYNC_SCRIPT" --check 2>/dev/null || {
        echo -e "${YELLOW}WARNING${NC} Versions may be out of sync"
        echo "  Run: python scripts/sync-versions.py"
    }
fi

# =============================================================================
# FINAL STATUS
# =============================================================================
echo ""
echo -e "${GREEN}Pre-push validation complete${NC}"
echo "Ready to push to $CURRENT_BRANCH"
exit 0
