{
  "manifest_version": 3,
  "name": "AI ChatNav",
  "version": "0.2.3",
  "description": "Navigate between user and AI messages in ChatGPT, Claude.ai, and other AI chat interfaces",
  "permissions": ["activeTab", "storage"],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
